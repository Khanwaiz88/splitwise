# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Production app URL (required on Vercel for invite links)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Local only — database migrations (not needed on Vercel)
# SUPABASE_DB_PASSWORD=

# Optional — email invites via Resend
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Splitwise <onboarding@resend.dev>
