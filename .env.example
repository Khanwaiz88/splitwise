# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Production app URL (required on Vercel for invite links + Google OAuth callback)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Google login (configure in Supabase Dashboard, not env vars):
# 1. Supabase → Authentication → Providers → Google → Enable
# 2. Google Cloud Console → OAuth client (Web) → add redirect URI:
#    https://YOUR-PROJECT.supabase.co/auth/v1/callback
# 3. Supabase → Authentication → URL Configuration → Redirect URLs:
#    https://your-app.vercel.app/auth/callback
#    http://localhost:3000/auth/callback

# Local only — database migrations (not needed on Vercel)
# SUPABASE_DB_PASSWORD=
# SUPABASE_DB_REGION=ap-south-1

# ── Group invite emails (pick ONE provider) ────────────────────────────────

# Option A: Resend (free API — 100 emails/day)
# Sign up: https://resend.com → API Keys
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=Splitwise <onboarding@resend.dev>
# For production, verify your domain in Resend and use:
# RESEND_FROM=Splitwise <invites@yourdomain.com>

# Option B: Gmail SMTP (free — ~500 emails/day)
# Use a Google App Password (not your login password):
# https://myaccount.google.com/apppasswords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-16-char-app-password
# SMTP_FROM=Splitwise <your@gmail.com>

# Option C: Brevo SMTP (free tier — 300 emails/day)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-brevo-login-email
# SMTP_PASS=your-brevo-smtp-key
# SMTP_FROM=Splitwise <your@email.com>
